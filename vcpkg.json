{
  "name": "spectraforge",
  "version": "0.1.0",
  "description": "SpectraForge - Spectral Processing Engine Combining Transform Rendering And Frequency Optimized Radiance Gaussian Encoding",
  "homepage": "https://github.com/TiGRoNdev/SpectraForge",
  "license": "MIT",
  "dependencies": [
    {
      "name": "glfw3"
    },
    {
      "name": "glew"
    },
    {
      "name": "vulkan-memory-allocator"
    },
    {
      "name": "vulkan-hpp"
    },
    {
      "name": "spirv-cross"
    },
    {
      "name": "shaderc"
    },
    {
      "name": "imgui",
      "features": ["vulkan-binding"]
    },
    {
      "name": "assimp"
    },
    {
      "name": "stb"
    },
    {
      "name": "glm"
    },
    {
      "name": "vkfft"
    },
    {
      "name": "glslang"
    },
    {
      "name": "gtest"
    }
  ],
  "features": {
    "examples": {
      "description": "Build example applications",
      "dependencies": []
    },
    "tests": {
      "description": "Build unit tests",
      "dependencies": [
        {
          "name": "gtest",
          "version>=": "1.12.0"
        }
      ]
    },
    "docs": {
      "description": "Build documentation",
      "dependencies": [
        {
          "name": "doxygen",
          "version>=": "1.9.0"
        }
      ]
    }
  }
}
